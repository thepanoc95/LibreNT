<UserControl
    x:Class="LibreNT.Shell.Components.StartMenu.StartMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="520"
    Height="600">

    <UserControl.Resources>
        <CornerRadius x:Key="StartMenuCornerRadius">8</CornerRadius>
    </UserControl.Resources>

    <Border Background="{ThemeResource SystemControlBackgroundBaseHighBrush}"
            CornerRadius="{StaticResource StartMenuCornerRadius}"
            Padding="12"
            DropShadow>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- User Profile Area -->
            <Border Grid.Row="0"
                    Background="{ThemeResource SystemControlBackgroundBaseMediumLowBrush}"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Image Source="../../../librentlogo.png"
                           Grid.Column="0"
                           Width="40"
                           Height="40"
                           VerticalAlignment="Center" />
                    
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="LibreNT User"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Free your WindowsNT"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Pinned Apps -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Hidden">
                <GridView x:Name="PinnedAppsGrid"
                          Margin="0,0,0,12"
                          ItemsSource="{x:Bind PinnedApps}"
                          SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Button Click="OnAppClick"
                                    Tag="{x:Bind Id}"
                                    Style="{StaticResource ButtonRevealStyle}"
                                    Padding="8"
                                    MinWidth="100"
                                    Height="80">
                                <StackPanel HorizontalAlignment="Center">
                                    <FontIcon Glyph="{x:Bind Icon}"
                                              FontFamily="Segoe MDL2 Assets"
                                              FontSize="24"
                                              HorizontalAlignment="Center" />
                                    <TextBlock Text="{x:Bind Name}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Width="80"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid Orientation="Horizontal"
                                     ItemWidth="100"
                                     ItemHeight="80" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                </GridView>
            </ScrollViewer>

            <!-- Power Options -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
                <Button x:Name="ShutdownButton"
                        Click="OnShutdownClick"
                        Style="{StaticResource ButtonRevealStyle}">
                    <FontIcon Glyph="&#xE704;"
                              FontFamily="Segoe MDL2 Assets" />
                </Button>
                <Button x:Name="RestartButton"
                        Click="OnRestartClick"
                        Style="{StaticResource ButtonRevealStyle}">
                    <FontIcon Glyph="&#xE701;"
                              FontFamily="Segoe MDL2 Assets" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>